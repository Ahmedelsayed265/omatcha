<script>
  // Lazy load images in modules and product grids that use data-src attribute
  document.addEventListener('DOMContentLoaded', function () {
    var moduleImages = document.querySelectorAll('[section-id] img[data-src], .products-grid img.lazy-img[data-src], #related-products img.lazy-img[data-src]');
    if (!moduleImages.length) return;

    function loadModuleImg(img) {
      var src = img.getAttribute('data-src');
      if (!src) return;
      img.src = src;
      img.removeAttribute('data-src');
    }

    if ('IntersectionObserver' in window) {
      var observer = new IntersectionObserver(function (entries, obs) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            loadModuleImg(entry.target);
            obs.unobserve(entry.target);
          }
        });
      }, { rootMargin: '200px 0px' });

      moduleImages.forEach(function (img) {
        observer.observe(img);
      });
    } else {
      moduleImages.forEach(loadModuleImg);
    }
  });
</script>

