<div class="overlay-popup overlay-main active"></div>
<script>
  document.addEventListener("DOMContentLoaded", function () {
    const popupSec = document.querySelector(".popup-main");
    const popupBox = popupSec?.querySelector(".popup-box");
    const overlay = document.querySelector(".overlay-main");
    const closeBtn = popupSec?.querySelector(".close-modal-custom");
    const ctaBtn = popupSec?.querySelector(".popup-cta-btn");

    if (!popupSec || !overlay) return;

    function openPopup() {
      popupSec.classList.add("active");
      overlay.classList.add("active");
    }

    function closePopup() {
      popupSec.classList.remove("active");
      overlay.classList.remove("active");
      localStorage.setItem("popup_main_last_seen", Date.now());
    }

    if (closeBtn) closeBtn.addEventListener("click", closePopup);

    if (ctaBtn) ctaBtn.addEventListener("click", function () { closePopup(); });

    if (overlay) overlay.addEventListener("click", closePopup);

    document.addEventListener("click", function (e) {
      if (popupBox && popupSec.classList.contains("active") && !popupBox.contains(e.target) && closeBtn && !closeBtn.contains(e.target)) {
        closePopup();
      }
    });

    var lastSeen = localStorage.getItem("popup_main_last_seen");
    var now = Date.now();
    var oneHour = 60 * 60 * 1000;
    if (!lastSeen || (now - parseInt(lastSeen, 10)) >= oneHour) {
      openPopup();
    } else {
      closePopup();
    }
  });
</script>
{% endif %}
