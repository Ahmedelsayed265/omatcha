<div id="menu-logo" style="display:none;">
	<a href="/" class="logo-menu">
		{% set logoUrl = store.settings.branding.logo %}
		<img loading="lazy" class="menu-logo lazy-img" width="180" height="60" src="{{ image_url(logoUrl,{ h: 175, q: 100 }) }}" alt="{{ store.name }}">
	</a>

	<div id="sliding-menu-customer-block" class="user-greeting sliding-menu-customer-block" onclick="window.location.href='{{ url_for("profile") }}'" {% if not (customer is defined and customer) %}style="display: none;"{% endif %}>
