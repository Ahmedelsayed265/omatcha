<nav id="sliding-menu" style="opacity: 0;position: fixed;">
	  <ul class="list-menu">
    {% for menu in store.settings.menus.main_menu.items %}
    {% if menu.url %}
    <li class="slide-menu-ul-li {% if menu.slug == 'all_categories' %} all-categories {% endif %}"
      onclick="scrollToSubMenu(this)">
      <a href="{{ menu.url }}" title="{{ menu.label }}" class="menu-link" aria-label="{{ menu.label }}">
        {% if menu.image_thumbnail %}
        <img loading="lazy" src="{{ menu.image_thumbnail }}" alt="menu" width="42" height="42"
          class="menu-image lazy-img" />
        {% endif %}
        <span class="clickable-span">{{ menu.label }}</span>
      </a>
      {% if menu.items | length > 0 %}
      <ul>
        {% for menu_sub in menu.items %}
        <li class="slide-menu-ul-li">
          <a href="{{ menu_sub.url }}" aria-label="{{ menu_sub.label }}">
            {% if menu_sub.image_thumbnail %}
            <img loading="lazy" src="{{ menu_sub.image_thumbnail }}" alt="menu-sub" width="42" height="42"
              class="menu-image lazy-img" />
            {% endif %}
            <span class="clickable-span">{{ menu_sub.label }}</span>
          </a>
          {% if menu_sub.items | length > 0 %}
          <ul>
            {% for menu_sub_sub in menu_sub.items %}
            <li class="slide-menu-ul-li">
              <a href="{{ menu_sub_sub.url }}" aria-label="{{ menu_sub_sub.label }}">
                {% if menu_sub_sub.image_thumbnail %}
                <img loading="lazy" src="{{ menu_sub_sub.image_thumbnail }}" alt="menu-sub-sub" width="42" height="42"
                  class="menu-image lazy-img" />
                {% endif %}
                {{ menu_sub_sub.label }}
              </a>
            </li>
            {% endfor %}
          </ul>
          {% endif %}
        </li>
        {% endfor %}
      </ul>
      {% endif %}
    </li>
    {% endif %}
    {% endfor %}
  </ul>
</nav>

<script>
(function() {
  function applySlidingMenuCustomer(customer) {
    if (!customer || !customer.name) return;
    document.querySelectorAll('.sliding-menu-customer-name').forEach(function(el) { el.textContent = customer.name; });
    document.querySelectorAll('.sliding-menu-customer-block').forEach(function(el) { el.style.display = ''; });
    document.querySelectorAll('.sliding-menu-guest-block').forEach(function(el) { el.style.display = 'none'; });
  }
  document.addEventListener('zid-customer-fetched', function (event) {
    var customer = event.detail && event.detail.customer;
    applySlidingMenuCustomer(customer);
  });
  if (window.zid && window.zid.customer) applySlidingMenuCustomer(window.zid.customer);
})();
</script>
