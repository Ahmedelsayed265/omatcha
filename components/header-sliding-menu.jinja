		<div class="user-info">
			<p class="user-name">{{ _('Hello') }}, <span id="sliding-menu-customer-name" class="sliding-menu-customer-name">{{ customer.name if (customer is defined and customer) else '' }}</span></p>
			<p class="welcome-text remove-underline">{{ _('Welcome to Shift Store') }}</p>
