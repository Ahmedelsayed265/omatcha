{% if reviews %}
	{% for review in reviews %}
		<div class="tp-product-details-review-avater">
			<div class="tp-product-details-review-avater-thumb">
				<div class="account_circle">
					<span>{{ review.customer.name|slice(0, 1) }}</span>
				</div>
			</div>
			<div class="tp-product-details-review-avater-content">
				<div class="tp-product-details-review-avater-rating">
					{% set rating = review.rating %}
					{% include 'components/rating-stars.jinja' %}
				</div>
				<h3 class="tp-product-details-review-avater-title">{{ review.customer.name }}</h3>
				<span class="tp-product-details-review-avater-meta" data-time-ago-date="{{ review.created_at }}"></span>
				<div class="tp-product-details-review-avater-comment">
					{{ review.comment | safe }}
				</div>
				{% if review.images %}
					<div class="review-images-box">
						{% for image in review.images %}
							<img loading="lazy" src="{{ image.path }}" attr-index="{{ loop.index0 }}" class="review-image-clickable" />
						{% endfor %}
					</div>
				{% endif %}
				{% if review.reply %}
					<div class="review-reply-box tp-product-details-review-avater">
						<div class="tp-product-details-review-avater-thumb">
							<div class="account_circle">
								<img loading="lazy" src="{{ store.settings.branding.logo }}" />
							</div>
						</div>
						<div class="tp-product-details-review-avater-content">
							<h3 class="tp-product-details-review-avater-title">{{ store.name }}</h3>
							<div class="tp-product-details-review-avater-comment">
								{{ review.reply.text | safe }}
							</div>
							{% if review.reply.images %}
								<div class="review-images-box">
									{% for image in review.reply.images %}
										<img loading="lazy" src="{{ image.path }}" attr-index="{{ loop.index0 }}" class="review-image-clickable" />
									{% endfor %}
								</div>
							{% endif %}
						</div>
					</div>
				{% endif %}
			</div>
		</div>
	{% endfor %}

<style>
.pswp__img {
  object-fit: contain;
}
</style>
<script>
$('.tp-product-details-review-avater .review-images-box img').on( "click", function() {
        var parent = $( this ).parent();
        var index = $( this ).attr('attr-index');
        var images = []
        $('img', parent).each(function(idx, itm) {
                images.push($(itm).attr('src'));
        });        
        openPhotoSwiper(images, index);
});

</script>

{% endif %}
