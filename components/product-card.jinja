								</svg>
							</a>
						{% else %}
							<button type="button" class="product-card-add-to-cart" onclick="productCartAddToCart(this,'{{ product.id }}')" aria-label="AddToCart">
								<img loading="lazy" style="display: inline" class="add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20"/>
								<svg width="21" height="22" viewBox="0 0 21 22" fill="none" xmlns="http://www.w3.org/2000/svg">
