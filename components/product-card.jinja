{% if product %}
<div>
	<div class="card-product-style-2 product-box {% if product.is_infinite == false and product.quantity <= 0 %}product-item-out-of-stock{% endif %}" product-id="{{ product.id }}">
    {% set _pre_order_ns = namespace(is_pre_order=false) %}
    {% for item in (pre_order_list or []) %}
      {% if item.product.id == product.id %}
        {% set _pre_order_ns.is_pre_order = true %}
      {% endif %}
    {% endfor %}
    {% set is_pre_order = _pre_order_ns.is_pre_order %}
    <div class="tp-product-container">
			<div class="img-and-btns">
				<a href="/products/{{ product.slug }}" class="tp-image-product">
					<div class="box-img-product">
						<img loading="lazy" class="lazy-img" width="200" height="300" id="product-card-img-{{ product.id }}-1" {% if product.images or product.videos %} data-src="{{ product.images[0]['image']['large'] or product.videos[0]['image']['large'] }}" {% else %} data-src="{{ image_url('product-img.svg' | asset_url,{ w: 235, q: 100, f:'auto' }) }}" {% endif %} alt="{{ product.name }}">
					</div>
					<div class="product-card-badges">
						{% if product.badge %}
							{% include 'vitrin:products/badge.jinja' %}
						{% endif %}
						<span class="product-card-bundle-offer" data-bundle-offer-product-id="{{ product.id }}"></span>
						{% if is_pre_order %}
							<span class="pre-order-badge">
								{{ _('Pre Order') }}
							</span>
						{% endif %}
					</div>
					{% if product.sale_price is not none %}
						<span class="discount">-
							{{ product.discount_percentage }}%</span>
					{% endif %}
					{% if product.is_infinite == false and product.quantity <= 0 %}
						<small class="out-of-stock">{{
              _('Out of stock') }}</small>
					{% endif %}
          {% for metafield in product.metafields %}
            {% if metafield.slug == 'version-number' %}
              <div class="version-number">
                <img loading="lazy" class="lazy-img" data-src="{{ metafield.value.full_size }}" alt="version-number">
              </div>
            {% endif %}
          {% endfor %}
				</a>
			</div>
			<div class="tp-content-wrapper">
				<a href="/products/{{ product.slug }}" class="tp-content-product">
					<h2>{{ product.name | safe }}</h2>
				</a>
        {% for metafield in product.metafields %}
          {% if metafield.slug == 'product-features' %}
            <div class="product-card-features">
              {% if session.lang == 'en' and metafield.value.en %}
                {{ metafield.value.en | safe }}
              {% else %}
                {{ metafield.value.ar | safe }}
              {% endif %}
            </div>
          {% endif %}
        {% endfor %}
				<div class="price-cart-btns">
					<div class="price-part">
						{% if product.sale_price is not none %}
							<div class="tp-price-product">
								<p class="price-new">{{ product.sale_price }}
									{{ product.currency_symbol }}</p>
								<div class="price-wafar">
									<span class="price-old">{{ product.price }}
										{{ product.currency_symbol }}</span>
								</div>
							</div>
						{% else %}
							<div class="tp-price-product">
								<p class="price-new">{{ product.price }}
									{{ product.currency_symbol }}</p>
							</div>
						{% endif %}
						{% if product.is_infinite or product.quantity > 0 %}
							{% if not product.is_taxable %}
								<small class="is-not-taxable">{{ _('Tax free') }}</small>
							{% endif %}
						{% endif %}
					</div>
					<div class="footer-btns">
						{% if product.is_infinite == false and product.quantity <= 0 %}
							<a class="btn-product-card-out-of-stock" disabled>
								<svg width="24" height="24" viewbox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
