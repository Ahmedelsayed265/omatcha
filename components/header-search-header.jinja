<div class="header-box">
	<div class="right-box">
		<div class="menu-btn">
			<div class="menu-box">
				<span></span>
				<span></span>
				<span></span>
			</div>
		</div>
	</div>
	<div class="middle-box">
		<a href="/">
			{% set logoUrl = store.settings.branding.logo %}
			<img loading="lazy" class="main-logo" width="180" height="42" src="{{ image_url(logoUrl,{ h: 175, q: 100 }) }}" alt="{{ store.name }}">
			{% if another_logo %}
				<img loading="lazy" class="another-logo" width="180" height="42" src="{{ image_url(another_logo ,{ h: 175, q: 100 }) }}" alt="{{ store.name }}">
			{% endif %}
		</a>
	</div>
	<div class="left-box">
		<div class="account-area">
            <button type="button" onclick="handleLoginAction()" id="login-btn">
                <svg width="20" height="22" viewBox="0 0 20 22" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path fill-rule="evenodd" clip-rule="evenodd" d="M3.94445 13.5869C7.49845 11.4709 12.0028 11.4707 15.5568 13.5869C15.6729 13.6561 15.8162 13.7375 15.9786 13.8291C16.6914 14.2312 17.7698 14.839 18.5079 15.5615C18.9696 16.0134 19.4077 16.6093 19.4874 17.3389C19.5722 18.1147 19.2337 18.8424 18.5548 19.4893C17.3834 20.6053 15.9776 21.5 14.1593 21.5H5.34093C3.52273 21.4999 2.11683 20.6053 0.945426 19.4893C0.266619 18.8424 -0.0719361 18.1146 0.0128091 17.3389C0.0925548 16.6093 0.53161 16.0134 0.993278 15.5615C1.73144 14.8391 2.80888 14.2312 3.5216 13.8291C3.68421 13.7374 3.82817 13.6562 3.94445 13.5869ZM14.7892 14.876C11.7081 13.0414 7.79315 13.0415 4.71203 14.876C4.54418 14.9759 4.35975 15.0802 4.16711 15.1895C3.4545 15.5937 2.6222 16.066 2.04211 16.6338C1.68204 16.9863 1.52858 17.2773 1.50402 17.502C1.48458 17.6803 1.53013 17.9742 1.98058 18.4033C3.01636 19.3901 4.0686 19.9999 5.34093 20H14.1593C15.4317 20 16.4848 19.3902 17.5206 18.4033C17.9708 17.9743 18.0157 17.6803 17.9962 17.502C17.9716 17.2773 17.8182 16.9863 17.4581 16.6338C16.878 16.066 16.0457 15.5937 15.3331 15.1895C15.1406 15.0802 14.9569 14.9759 14.7892 14.876ZM9.75011 0C12.6496 0 15.0001 2.3505 15.0001 5.25C15.0001 8.14949 12.6496 10.5 9.75011 10.5C6.85062 10.5 4.50011 8.14949 4.50011 5.25C4.50011 2.3505 6.85062 0 9.75011 0ZM9.75011 1.5C7.67905 1.5 6.00011 3.17893 6.00011 5.25C6.00011 7.32107 7.67905 9 9.75011 9C11.8212 9 13.5001 7.32107 13.5001 5.25C13.5001 3.17893 11.8212 1.5 9.75011 1.5Z" fill="#FAFAFA"/>
				</svg>
            </button>

            <button type="button" onclick="window.location.href='{{ url_for("profile") }}'" id="hello-btn" style="display: none;">
                <svg width="20" height="22" viewBox="0 0 20 22" fill="none" xmlns="http://www.w3.org/2000/svg">
					<path fill-rule="evenodd" clip-rule="evenodd" d="M3.94445 13.5869C7.49845 11.4709 12.0028 11.4707 15.5568 13.5869C15.6729 13.6561 15.8162 13.7375 15.9786 13.8291C16.6914 14.2312 17.7698 14.839 18.5079 15.5615C18.9696 16.0134 19.4077 16.6093 19.4874 17.3389C19.5722 18.1147 19.2337 18.8424 18.5548 19.4893C17.3834 20.6053 15.9776 21.5 14.1593 21.5H5.34093C3.52273 21.4999 2.11683 20.6053 0.945426 19.4893C0.266619 18.8424 -0.0719361 18.1146 0.0128091 17.3389C0.0925548 16.6093 0.53161 16.0134 0.993278 15.5615C1.73144 14.8391 2.80888 14.2312 3.5216 13.8291C3.68421 13.7374 3.82817 13.6562 3.94445 13.5869ZM14.7892 14.876C11.7081 13.0414 7.79315 13.0415 4.71203 14.876C4.54418 14.9759 4.35975 15.0802 4.16711 15.1895C3.4545 15.5937 2.6222 16.066 2.04211 16.6338C1.68204 16.9863 1.52858 17.2773 1.50402 17.502C1.48458 17.6803 1.53013 17.9742 1.98058 18.4033C3.01636 19.3901 4.0686 19.9999 5.34093 20H14.1593C15.4317 20 16.4848 19.3902 17.5206 18.4033C17.9708 17.9743 18.0157 17.6803 17.9962 17.502C17.9716 17.2773 17.8182 16.9863 17.4581 16.6338C16.878 16.066 16.0457 15.5937 15.3331 15.1895C15.1406 15.0802 14.9569 14.9759 14.7892 14.876ZM9.75011 0C12.6496 0 15.0001 2.3505 15.0001 5.25C15.0001 8.14949 12.6496 10.5 9.75011 10.5C6.85062 10.5 4.50011 8.14949 4.50011 5.25C4.50011 2.3505 6.85062 0 9.75011 0ZM9.75011 1.5C7.67905 1.5 6.00011 3.17893 6.00011 5.25C6.00011 7.32107 7.67905 9 9.75011 9C11.8212 9 13.5001 7.32107 13.5001 5.25C13.5001 3.17893 11.8212 1.5 9.75011 1.5Z" fill="#FAFAFA"/>
				</svg>
            </button>
        </div>

		<div class="search-box">
				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="24" height="24" color="#000000" fill="none">
					<path d="M17.5 17.5L22 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M20 11C20 6.02944 15.9706 2 11 2C6.02944 2 2 6.02944 2 11C2 15.9706 6.02944 20 11 20C15.9706 20 20 15.9706 20 11Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
				</svg>
			</div>
		<div class="cart-btn">
			<a data-bs-toggle="offcanvas" href="#side-cart" aria-controls="side-cart" role="button" aria-label="cart">
				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="24" height="24" color="#000000" fill="none">
					<path d="M3.87289 17.0194L2.66933 9.83981C2.48735 8.75428 2.39637 8.21152 2.68773 7.85576C2.9791 7.5 3.51461 7.5 4.58564 7.5H19.4144C20.4854 7.5 21.0209 7.5 21.3123 7.85576C21.6036 8.21152 21.5126 8.75428 21.3307 9.83981L20.1271 17.0194C19.7282 19.3991 19.5287 20.5889 18.7143 21.2945C17.9 22 16.726 22 14.3782 22H9.62182C7.27396 22 6.10003 22 5.28565 21.2945C4.47127 20.5889 4.27181 19.3991 3.87289 17.0194Z" stroke="currentColor" stroke-width="1.5"/>
					<path d="M17.5 7.5C17.5 4.46243 15.0376 2 12 2C8.96243 2 6.5 4.46243 6.5 7.5" stroke="currentColor" stroke-width="1.5"/>
				</svg>
				<span class="cart-badge">0</span>
			</a>
		</div>
		{% if store.settings.checkout.gift_order_settings.is_gift_order_enabled == '1' %}
			<div id="tooltip" class="d-none popover popover-gift" role="tooltip">
				<div class="arrow"></div>
				<div class="gift-popover-body">
					<img loading="lazy" src="{{ 'gift-popover-icon.svg' | asset_url }}" width="24" height="24"/>
					<p class="h6 my-2">
						{{ _('Send as gift') }}
					</p>
					<button class="btn round primary d-block">
						<a href="/cart/view" class="no-border d-block">
							{{ _('continue') }}
						</a>
					</button>
				</div>
			</div>
		{% endif %}
	</div>
</div>

<script>
document.addEventListener('zid-customer-fetched', function (event) {
    const customer = event.detail.customer;
    if (customer && customer.name) {
        document.getElementById('hello-btn').style.display = 'inline-block';
        document.getElementById('login-btn').style.display = 'none';
    }
});
</script>