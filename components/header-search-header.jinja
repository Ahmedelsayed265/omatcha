<div class="header-box">
	<div class="right-box">
		<div class="menu-btn">
			<div class="menu-box">
				<span></span>
				<span></span>
				<span></span>
			</div>
		</div>
	</div>
	<div class="middle-box">
		<a href="/">
			{% set logoUrl = store.settings.branding.logo %}
			<img loading="lazy" class="main-logo" width="180" height="42" src="{{ image_url(logoUrl,{ h: 175, q: 100 }) }}" alt="{{ store.name }}">
			{% if another_logo %}
				<img loading="lazy" class="another-logo" width="180" height="42" src="{{ image_url(another_logo ,{ h: 175, q: 100 }) }}" alt="{{ store.name }}">
			{% endif %}
		</a>
	</div>
	<div class="left-box">
		<div class="search-box">
				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="24" height="24" color="#000000" fill="none">
					<path d="M17.5 17.5L22 22" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
					<path d="M20 11C20 6.02944 15.9706 2 11 2C6.02944 2 2 6.02944 2 11C2 15.9706 6.02944 20 11 20C15.9706 20 20 15.9706 20 11Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
				</svg>
			</div>
		<div class="cart-btn">
			<a data-bs-toggle="offcanvas" href="#side-cart" aria-controls="side-cart" role="button" aria-label="cart">
				<svg xmlns="http://www.w3.org/2000/svg" viewbox="0 0 24 24" width="24" height="24" color="#000000" fill="none">
					<path d="M3.87289 17.0194L2.66933 9.83981C2.48735 8.75428 2.39637 8.21152 2.68773 7.85576C2.9791 7.5 3.51461 7.5 4.58564 7.5H19.4144C20.4854 7.5 21.0209 7.5 21.3123 7.85576C21.6036 8.21152 21.5126 8.75428 21.3307 9.83981L20.1271 17.0194C19.7282 19.3991 19.5287 20.5889 18.7143 21.2945C17.9 22 16.726 22 14.3782 22H9.62182C7.27396 22 6.10003 22 5.28565 21.2945C4.47127 20.5889 4.27181 19.3991 3.87289 17.0194Z" stroke="currentColor" stroke-width="1.5"/>
					<path d="M17.5 7.5C17.5 4.46243 15.0376 2 12 2C8.96243 2 6.5 4.46243 6.5 7.5" stroke="currentColor" stroke-width="1.5"/>
				</svg>
				<span class="cart-badge">0</span>
			</a>
		</div>
		{% if store.settings.checkout.gift_order_settings.is_gift_order_enabled == '1' %}
			<div id="tooltip" class="d-none popover popover-gift" role="tooltip">
				<div class="arrow"></div>
				<div class="gift-popover-body">
					<img loading="lazy" src="{{ 'gift-popover-icon.svg' | asset_url }}" width="24" height="24"/>
					<p class="h6 my-2">
						{{ _('Send as gift') }}
					</p>
					<button class="btn round primary d-block">
						<a href="/cart/view" class="no-border d-block">
              {{ _('continue') }}
						</a>
					</button>
				</div>
			</div>
		{% endif %}
	</div>
</div>
