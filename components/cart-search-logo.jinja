<div class="cart-search-logo d-flex align-items-center" style="background: #6D192B">
    <div class="container d-flex justify-content-between align-items-center">
        <div class="search-and-logo d-flex flex-grow-1 align-items-center">
            <div class="store-logo">
                {% set width = '100' %}
                {% set height = '100' %}
                {% include 'components/logo.jinja' %}
            </div>
            <div class="search-bar flex-grow-1">
                <input id="search-input" placeholder="{{ _('Search') }}" autocomplete="off" spellcheck="false">
                <img loading="lazy" src="{{ 'search-icon.svg' | asset_url }}" alt="search-icon" width="31" height="31">
            </div>
        </div>
        <a class="cart-section d-flex text-center" onclick="showShoppingCart();">
            <div class="cart-total-price d-flex flex-row-reverse px-4">
                <span id="cart-total"></span>
                <span class="mx-2">{{ session.currency.code }}</span>
            </div>
            <div class="cart-icon-section">
                <img loading="lazy" src="{{ 'cart-icon.svg' | asset_url }}" alt="cart-icon" width="31" height="31">
                <div id="cart-counter" class="cart-items-counter"></div>
            </div>
            <img loading="lazy" src="{{ 'drop-down.svg' | asset_url }}" alt="drop-down" width="31" height="31">
        </a>
        <div id="header-shopping-cart" class="cart-sidebar d-flex flex-column">
            <div class="cart-sidebar-header m-5">
                <div onclick="hideShoppingCart();">X</div>
                {{ _('Cart') }}
            </div>
            <div id="cart-items" class="d-flex flex-column m-5"></div>
            <div id="empty-cart" class="text-center flex-column text-center flex-grow-1 justify-content-center">
                <div><img loading="lazy" src="{{ 'empty-cart.svg' | asset_url }}" alt="empty-cart" width="84" height="88"></div>
                <div class="empty-cart-title text-nowrap pt-3">{{ _('Cart is empty') }}</div>
            </div>
        </div>
    </div>
</div>
