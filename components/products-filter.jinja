<div class="tp-shop-top">
  <div class="tp-shop-top-right">
    <div class="tp-shop-top-filter {% if has_products_filtration %}d-none{% else %}d-inline-block{% endif %}">
      <button type="button" class="tp-filter-btn tp-btn tp-btn-primary-outline filter-open-btn" id="products-list-filter" data-bs-toggle="modal"
        data-bs-target="#filterModal">
        <span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" color="#ffffff"
            fill="none">
            <path d="M3 7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M3 17H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M18 17L21 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
              stroke-linejoin="round" />
            <path d="M15 7L21 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
              stroke-linejoin="round" />
            <path
              d="M6 7C6 6.06812 6 5.60218 6.15224 5.23463C6.35523 4.74458 6.74458 4.35523 7.23463 4.15224C7.60218 4 8.06812 4 9 4C9.93188 4 10.3978 4 10.7654 4.15224C11.2554 4.35523 11.6448 4.74458 11.8478 5.23463C12 5.60218 12 6.06812 12 7C12 7.93188 12 8.39782 11.8478 8.76537C11.6448 9.25542 11.2554 9.64477 10.7654 9.84776C10.3978 10 9.93188 10 9 10C8.06812 10 7.60218 10 7.23463 9.84776C6.74458 9.64477 6.35523 9.25542 6.15224 8.76537C6 8.39782 6 7.93188 6 7Z"
              stroke="currentColor" stroke-width="1.5" />
            <path
              d="M12 17C12 16.0681 12 15.6022 12.1522 15.2346C12.3552 14.7446 12.7446 14.3552 13.2346 14.1522C13.6022 14 14.0681 14 15 14C15.9319 14 16.3978 14 16.7654 14.1522C17.2554 14.3552 17.6448 14.7446 17.8478 15.2346C18 15.6022 18 16.0681 18 17C18 17.9319 18 18.3978 17.8478 18.7654C17.6448 19.2554 17.2554 19.6448 16.7654 19.8478C16.3978 20 15.9319 20 15 20C14.0681 20 13.6022 20 13.2346 19.8478C12.7446 19.6448 12.3552 19.2554 12.1522 18.7654C12 18.3978 12 17.9319 12 17Z"
              stroke="currentColor" stroke-width="1.5" />
          </svg>
        </span>
        {{ _('Filter') }}
      </button>
    </div>
    <div class="tp-shop-top-filter open-close-filter {% if has_products_filtration %}d-inline-block{% else %}d-none{% endif %}">
      <button type="button" class="tp-filter-btn tp-btn tp-btn-primary-outline">
        <span>
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" color="#ffffff"
            fill="none">
            <path d="M3 7H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M3 17H9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M18 17L21 17" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
              stroke-linejoin="round" />
            <path d="M15 7L21 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
              stroke-linejoin="round" />
            <path
              d="M6 7C6 6.06812 6 5.60218 6.15224 5.23463C6.35523 4.74458 6.74458 4.35523 7.23463 4.15224C7.60218 4 8.06812 4 9 4C9.93188 4 10.3978 4 10.7654 4.15224C11.2554 4.35523 11.6448 4.74458 11.8478 5.23463C12 5.60218 12 6.06812 12 7C12 7.93188 12 8.39782 11.8478 8.76537C11.6448 9.25542 11.2554 9.64477 10.7654 9.84776C10.3978 10 9.93188 10 9 10C8.06812 10 7.60218 10 7.23463 9.84776C6.74458 9.64477 6.35523 9.25542 6.15224 8.76537C6 8.39782 6 7.93188 6 7Z"
              stroke="currentColor" stroke-width="1.5" />
            <path
              d="M12 17C12 16.0681 12 15.6022 12.1522 15.2346C12.3552 14.7446 12.7446 14.3552 13.2346 14.1522C13.6022 14 14.0681 14 15 14C15.9319 14 16.3978 14 16.7654 14.1522C17.2554 14.3552 17.6448 14.7446 17.8478 15.2346C18 15.6022 18 16.0681 18 17C18 17.9319 18 18.3978 17.8478 18.7654C17.6448 19.2554 17.2554 19.6448 16.7654 19.8478C16.3978 20 15.9319 20 15 20C14.0681 20 13.6022 20 13.2346 19.8478C12.7446 19.6448 12.3552 19.2554 12.1522 18.7654C12 18.3978 12 17.9319 12 17Z"
              stroke="currentColor" stroke-width="1.5" />
          </svg>
        </span>
        {{ _('Filter') }}
      </button>
    </div>
    <div class="tp-shop-top-result">
      {% if count > 0 %}
      <p>{{ _('Showing') }} <b id="product-filter-count">{{count}}</b> {{ _('products') }}</p>
      {% else %}
      <p>{{ _('No products') }}</p>
      {% endif %}
    </div>
  </div>
  <div class="tp-shop-top-left">
    <div class="dropdown tp-shop-top-select">
  <button id="products-list-sort" type="button" class="btn-sort" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
    
    <span>
        {% if session.query_params.get('sort_by') == 'popularity_order' %}
            {{ _('Popularity') }}
        {% elif session.query_params.get('sort_by') == 'price' and session.query_params.get('order') == 'asc' %}
            {{ _('Price') }}: {{ _('Low to high') }}
        {% elif session.query_params.get('sort_by') == 'price' and session.query_params.get('order') == 'desc' %}
            {{ _('Price') }}: {{ _('High to low') }}
        {% else %}
            {{ _('Newest') }}
        {% endif %}
    </span>

    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" color="#ffffff" fill="none">
      <path d="M18 9.00005C18 9.00005 13.5811 15 12 15C10.4188 15 6 9 6 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
<div class="dropdown-menu select-dropdown">
  <a class="dropdown-item" onclick="this.href = this.getAttribute('data-href')" data-href="{{ session.url.include_query_params(sort_by='created_at', order='desc') }}">
      {{ _('Newest') }}
  </a>
  <a class="dropdown-item" onclick="this.href = this.getAttribute('data-href')" data-href="{{ session.url.include_query_params(sort_by='popularity_order', order='asc') }}">
      {{ _('Popularity') }}
  </a>
  <a class="dropdown-item" onclick="this.href = this.getAttribute('data-href')" data-href="{{ session.url.include_query_params(sort_by='price', order='asc') }}">
      {{ _('Price') }}: {{ _('Low to high') }}
  </a>
  <a class="dropdown-item" onclick="this.href = this.getAttribute('data-href')" data-href="{{ session.url.include_query_params(sort_by='price', order='desc') }}">
      {{ _('Price') }}: {{ _('High to low') }}
  </a>
</div>

</div>

