{% extends "layout.jinja" %}



{% block header %} {% include 'header.jinja' %} {% endblock %}


{% block top_links %}
    <link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
    <link rel="stylesheet" type="text/css" href="{{ 'cart.css' | asset_url }}" />
{% endblock %}

{% block main_content %}

<div class="breadcrumb-subtitle">
      <section class="breadcrumb-section">
        <div class="container">
          <nav aria-label="breadcrumb">
              <ol class="breadcrumb">
                <li class="breadcrumb-item" aria-current="page">
                  <a href="/">{{ _('Home') }}</a>
                </li>
                <li class="breadcrumb-item active " aria-current="page">{{ _('Cart') }}</li>
              </ol>
          </nav>
        </div>
      </section>
      {% set title = _('Cart') %}
      {% include 'components/breadcrumb-subTitle-detail.jinja' %}
    </div>


    <div class="modal" id="searchCitiesModal" tabindex="-1" role="dialog">
      <div class="modal-dialog modal-dialog-centered" role="document">
        <div class="modal-content">
          <div class="modal-body" style="padding: 10px 20px 20px">
              <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>

              <h5 class="text-center py-3 mb-0 text-color-primary">
                {{ _('Free shipping to selected cities') }}
              </h5>

              <div class="p-2 d-lg-flex align-items-center bd-highlight search-input lg-search-div flex-grow-1">
                <div class="form-group" style="position: relative; margin: 0px">
                    <span class="icon-search search-input-icon" style="z-index: 1"></span>
                    <div class="autocomplete" style="position: relative">
                        <input type="text" data-cat-id="" class="form-control cities-search-input pl-5" placeholder="{{ _('Search') }}">
                    </div>
                </div>
            </div>

              <div>
                <p class="cities-result lead">
                  {% for city in safeget(cart, 'free_shipping_rule.shipping_cities_condition', []) %}
                    {{ city.name }}
                    {% if not loop.last %} ، {% endif %}
                  {% endfor %}
                </p>
              </div>

              <div class="d-flex justify-content-center mt-3">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" style="width: 120px">{{ _('Cancel') }}</button>
              </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container">

        {# تنبيه إصدارات مختلفة #}
        <style>
            #different-versions-alert {
              animation: pulse-alert 2s ease-in-out infinite;
              border-right: 4px solid #ffc107;
              border-radius: 10px;
              background: linear-gradient(135deg, #fff3cd 0%, #ffe69c 50%, #fff3cd 100%);
              background-size: 200% 200%;
              animation: pulse-alert 2s ease-in-out infinite, gradient-shift 3s ease infinite;
              position: relative;
              overflow: hidden;
            }

            #different-versions-alert::before {
              content: '';
              position: absolute;
              top: 0;
              right: 0;
              width: 4px;
              height: 100%;
              background: linear-gradient(180deg, #ffc107, #ff9800, #ffc107);
              animation: glow-border 2s ease-in-out infinite;
              box-shadow: 0 0 10px rgba(255, 193, 7, 0.8), 0 0 20px rgba(255, 193, 7, 0.6);
            }

            .ltr #different-versions-alert::before {
              right: auto;
              left: 0;
            }

            .ltr #different-versions-alert {
              border-right: 0;
              border-left: 4px solid #ffc107
            }
            
            @keyframes pulse-alert {
                0%, 100% {
                    transform: scale(1);
                }
                50% {
                    transform: scale(1.02);
                }
            }

            @keyframes gradient-shift {
                0% {
                    background-position: 0% 50%;
                }
                50% {
                    background-position: 100% 50%;
                }
                100% {
                    background-position: 0% 50%;
                }
            }

            @keyframes glow-border {
                0%, 100% {
                    opacity: 1;
                    box-shadow: 0 0 10px rgba(255, 193, 7, 0.8), 0 0 20px rgba(255, 193, 7, 0.6);
                }
                50% {
                    opacity: 0.8;
                    box-shadow: 0 0 15px rgba(255, 193, 7, 1), 0 0 30px rgba(255, 193, 7, 0.8);
                }
            }
            
            #different-versions-alert strong {
                display: inline-block;
                color: #856404;
                text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
            }
        </style>
        <div id="different-versions-alert" class="alert alert-warning d-none" role="alert" style="margin-bottom: 20px;">
            {% if session.lang == 'ar' %}
                <strong>تنبيه:</strong> فلتر الكبسولات وفلتر شيفت لا تتوافق مع بعض عند التركيب. هل انت متأكد من اتمام الطلب؟
            {% else %}
                <strong>Warning:</strong> Capsule filter and Shift filter are not compatible when installed together. Are you sure you want to complete the order?
            {% endif %}
        </div>

    
        <div class="cart-view">
            <div class="cart-products-with-totals {% if cart.products_count <= 0 %}d-none{% endif %}">
                <div class="cart-flex">
                    <div class="section-cart-products">
                      {# <h2 class="section-title">{{ _('Cart') }}</h2> #}
                        <div class="template_for_cart_products_list">
                            {% include 'vitrin:cart/products_list.jinja' %}
                        </div>

                        <div class="cart-gift-card" data-gift-removed-success="{{ _('Gift card removed successfully') }}"
                            data-gift-added-success="{{ _('Send Successfully') }}"
                            style="display: {% if cart.gift_card_details and cart.gift_card_details | length > 0 %}block{% else %}none{% endif %};">
                            <div class="d-flex align-items-start">
                                <span class="gift-card-icon-wrapper">
                                    <span class="icon-gift gift-icon-fallback"></span>
                                    <img src="{% if cart.gift_card_details and cart.gift_card_details.card_design %}{{ cart.gift_card_details.card_design }}{% endif %}"
                                        class="gift-card-image {% if not cart.gift_card_details or not cart.gift_card_details.card_design %}d-none{% endif %}"
                                        alt="Gift card design" />
                                </span>
                                <div class="gift-card-content flex-grow-1">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <p class="mb-0 gift-title">{{ _('Gift') }}</p>
                                        <p class="mb-0 gift-price-label">{{ _('Free') }}</p>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-start gift-card-details-row">
                                        <div class="gift-card-info">
                                            <p class="mb-0 gift-sender-recipient">
                                                <span class="sender-label">{{ _("Sender") }}:</span> <span
                                                    class="sender-name">{{cart.gift_card_details.sender_name if cart.gift_card_details else
                                                    ''}}</span>;
                                                <span class="recipient-label">{{ _("Recipient") }}:</span> <span
                                                    class="receiver-name">{{cart.gift_card_details.receiver_name if cart.gift_card_details else
                                                    ''}}</span>
                                            </p>
                                            <p class="mb-0 message-info"
                                                style="display: {% if cart.gift_card_details and cart.gift_card_details.gift_message and cart.gift_card_details.gift_message | length > 0 %}block{% else %}none{% endif %};">
                                                <span class="gift-message">{{ cart.gift_card_details.gift_message if cart.gift_card_details else
                                                    '' }}</span>
                                            </p>
                                            <p class="mb-0 media-link-info"
                                                style="display: {% if cart.gift_card_details and cart.gift_card_details.media_link and cart.gift_card_details.media_link | length > 0 %}block{% else %}none{% endif %};">
                                                <span class="gift-media-link">{{ cart.gift_card_details.media_link if cart.gift_card_details
                                                    else '' }}</span>
                                            </p>
                                        </div>
                                        <div class="gift-card-actions">
                                            <button type="button" class="btn btn-sm btn-link gift-card-edit-btn" onclick="editGiftCard()"
                                                title="{{ _('Edit') }}">
                                                <img src="{{ 'edit-icon.svg' | asset_url }}" alt="Edit" class="gift-card-edit-icon" />
                                            </button>
                                            <button type="button" class="btn btn-sm btn-link gift-card-delete-btn" onclick="deleteGiftCard()"
                                                title="{{ _('Delete') }}">
                                                <span class="icon-trash-alt"></span>
                                                <img class="delete-gift-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="15"
                                                    height="15" />
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <ul class="features-product">
                                {% for item in features_cart %}
                                <li>
                                  {% if item.image_feature %}
                                    <img loading="lazy" src="{{ image_url(item.image_feature) }}" loading="lazy" alt="{{ item.title_feature }}">
                                  {% endif %}
                                  <div class="content-features-product">
                                    {% if item.title_feature %}
                                      <h3>{{ item.title_feature }}</h3>
                                    {% endif %}
                                    {% if item.subtitle_feature %}
                                      <p>{{ item.subtitle_feature }}</p>
                                    {% endif %}
                                  </div>
                                </li>
                                {% endfor %}
                              </ul>

                    </div>

                    <div class="cart-totals">
                      <h2 class="section-title ">{{ _('Total summary') }}</h2>
                      <div>{% include 'components/cart_loyalty_points_widget.jinja' %}</div>
                      <div class="cart-totals-div">
                          {% for cartTotal in cart.totals %}
                              <div class="cart-product-row-wrapper cart-totals-row-wrapper">
                                  <h3>
                                      {{ cartTotal.title }}
                                      {% if cartTotal.code == 'total' and store.is_cart_total_vat_included %}&nbsp;<small>{{ _('Including VAT') }}</small>{% endif %}
                                  </h3>
                                  <p class="{% if cartTotal.code == 'total' %} total-price-p {% endif %}">
                                      {{ cartTotal.value_string }}
                                  </p>
                              </div>
                          {% endfor %}
                      </div>
                        <div class="coupon-form">
                          <form>
                              <div class="form-group">
                                  <h4>{{ _('Coupon') }}</h4>
                                  <div class="d-flex">
                                      <input class="form-control send-coupon" type="text" placeholder="{{ _('Enter coupon code') }}" />
                                      <button type="button" class="tp-btn tp-btn-primary-outline" onclick="sendCoupon(this)">
                                          <img loading="lazy" class="send-coupon-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"/>
                                          {{ _('Apply') }}
                                      </button>
                                  </div>
                              </div>
                          </form>
                          {% if cart.coupon.message %}
                              <div class="message-coupon" role="alert">
                                  <span>{{ cart.coupon.message }}</span>&nbsp;
                                  <a onclick="deleteCoupon(this)">
                                      <span class="icon-trash-alt"></span>
                                      <img loading="lazy" class="delete-coupon-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"/>
                                  </a>
                              </div>
                          {% endif %}
                        </div>
                      <div>{% include 'vitrin:cart/payment_widgets.jinja' %}</div>

                      {% if cart.free_shipping_rule and cart.free_shipping_rule.code %}
                        {% set status = cart.free_shipping_rule.subtotal_condition.status | default('') %}
                        {% set subtotal_condition = cart.free_shipping_rule.subtotal_condition %}
                        <div class="cart-discount-rule-wrapper free-shipping-rule-section mt-3">
                          <div class="d-flex align-items-center">
                              <div class="message flex-grow-1 free-shipping-rule-message">
                                 {% if status == 'min_not_reached' %}
                                    {{ _("Add products with total of %(total)s to get free shipping") | format(total=subtotal_condition.remaining | default("0")) }}
                                {% elif status == 'max_exceed' %}
                                    {{ _("Free shipping applied for cart total between %(min)s and %(max)s") | format(min=subtotal_condition.min_string | default("0"), max=subtotal_condition.max_string | default("0")) }}
                                {% elif status == 'applied' %}
                                    {{  _("Free shipping applied") }}
                                {% endif %}
                              </div>
                              <div class="text-muted mr-1 flex-shrink-0 free-shipping-rule-read-more {% if status == 'min_not_reached' %}d-inline-block{% else %}d-none{% endif %}">
                                <a data-bs-toggle="modal" data-bs-target="#searchCitiesModal" href="#">
                                  <small>
                                    {{ _("Read More") }}
                                  </small>
                                </a>
                              </div>
                              <div class="discount-progress flex-shrink-0">
                                  <span class="free-shipping-rule-done {% if status == 'applied' %}d-flex{% else %}d-none{% endif %}">
                                      <span style="font-size: 18px"  class="icon-done text-color-primary"></span>
                                  </span>
                              </div>
                          </div>
                          <div class="{% if status == 'min_not_reached' %}d-block{% else %}d-none{% endif %} discount-progress-linear">
                              <div class="progress-bar free-shipping-rule-progress" style="width: {{ subtotal_condition.products_subtotal_percentage_from_min | default(0) }}%">
                                {% if status == 'applied' %}
                                <span>{{ _("Free Shipping") }}</span>
                                {% else %}
                                <span>{{ subtotal_condition.products_subtotal_percentage_from_min | default(0) }}%</span>
                                {% endif %}
                            </div>
                          </div>
                        </div>
                        {% endif %}

                      <div>
                          <div class="btns-cart">
                              {% if store.settings.general.availability.closed_now %}
                                  <a href="#" class="tp-btn tp-btn-primary btn-disabled">
                                      {{ _('Complete Order') }}
                                  </a>
                              {% else %}
                                <a zid-visible-customer="true" href="/checkout/choose-address-and-shipping"
                                class="tp-btn tp-btn-primary">
                                    {{ _('Complete Order') }}
                                </a>
                                 <a zid-visible-guest="true" href="/auth/login?redirect_to=/checkout/choose-address-and-shipping"
                                class="tp-btn tp-btn-primary">
                                    {{ _('Complete Order') }}
                                </a>
                                  <div style="margin-top: 1rem">
                                      {% include 'vitrin:checkout/apple-pay-quick-checkout.jinja' %}
                                  </div>
                              {% endif %}
                          </div>

                          {% if store|attr('gift_order_settings') and store.gift_order_settings.is_gift_order_enabled == '1' %}
                            <div class="card border-0 mt-3 text-body">
                                {% include 'vitrin:cart/gift-card.jinja' %}
                            </div>
                          {% endif %}

                          <div class="btns-cart">
                              <a href="/" class="tp-btn tp-btn-primary-outline">
                                  {{ _('Continue shopping') }}
                              </a>
                          </div>
                      </div>

                  </div>
                  
                </div>
            </div>

            <div class="cart-empty {% if cart.products_count > 0 %}d-none{% endif %}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="48" height="48" color="#ffffff" fill="none">
                <path d="M8 16H15.2632C19.7508 16 20.4333 13.1808 21.261 9.06908C21.4998 7.88311 21.6192 7.29013 21.3321 6.89507C21.045 6.5 20.4947 6.5 19.3941 6.5H6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M8 16L5.37873 3.51493C5.15615 2.62459 4.35618 2 3.43845 2H2.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                <path d="M8.88 16H8.46857C7.10522 16 6 17.1513 6 18.5714C6 18.8081 6.1842 19 6.41143 19H17.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                <circle cx="10.5" cy="20.5" r="1.5" stroke="currentColor" stroke-width="1.5" />
                <circle cx="17.5" cy="20.5" r="1.5" stroke="currentColor" stroke-width="1.5" />
              </svg>
              <h3>{{ _('Cart is empty') }}</h3>
              <a href="/" class="tp-btn">
                  {{ _('Continue shopping') }}
              </a>
            </div>
        </div>
    </div>

{% endblock %}

{% block footer_scripts %}
    <script type="text/javascript" src="{{ 'toastr.min.js' | asset_url }}"></script>
<script type="text/javascript" src="{{ 'gift-card.js' | asset_url }}" defer></script>
    {{ cart_view_scripts| safe }}

    <script>

        $( document ).ready(function() {
            addDeleteProgressImage()
        });

        function addDeleteProgressImage(){
            $('.cart-product-delete a .prefix', document).addClass('d-none');
            $('.cart-product-delete a .prefix', document).html('<img loading="lazy" class="send-coupon-progress" src="{{ 'spinner.gif' | asset_url }}" width="15" height="15"/>');
        }

        $(document).on('click','.cart-product-delete a', function(event) {
            $('.icon-delete', event.currentTarget).addClass('d-none');
            $('.prefix',event.currentTarget).removeClass('d-none');
        });

        // تطبيق الكوبون — متوافق مع واجهة zid.cart الجديدة
        function sendCoupon(element) {
            var $form = element ? $(element).closest('.coupon-form') : $('.coupon-form').first();
            var $input = $form.find('.send-coupon');
            var $spinner = $form.find('.send-coupon-progress');
            if (!$spinner.length) $spinner = $('.send-coupon-progress').first();
            if (!$spinner.hasClass('d-none')) return;
            $spinner.removeClass('d-none');
            if (window.zid && window.zid.cart && typeof window.zid.cart.applyCoupon === 'function') {
                window.zid.cart.applyCoupon({ coupon_code: $input.val() }, { showErrorNotification: true })
                    .then(function () {
                        $spinner.addClass('d-none');
                        if (typeof toastr !== 'undefined') toastr.success('{{ _("Send Successfully") }}');
                        else if (window.zid && window.zid.toaster) window.zid.toaster.showSuccess('{{ _("Send Successfully") }}');
                        window.location.reload();
                    })
                    .catch(function () { $spinner.addClass('d-none'); });
            } else if (typeof zid !== 'undefined' && zid.store && zid.store.cart && typeof zid.store.cart.redeemCoupon === 'function') {
                zid.store.cart.redeemCoupon($input.val())
                    .then(function (response) {
                        $spinner.addClass('d-none');
                        if (response.status === 'success') {
                            if (typeof toastr !== 'undefined') toastr.success(window.i18n && window.i18n.success ? window.i18n.success : '{{ _("Send Successfully") }}');
                            window.location.reload();
                        } else {
                            var msg = (response.data && response.data.message) || (window.i18n && window.i18n.error) || '{{ _("Sorry") }}';
                            if (typeof toastr !== 'undefined') toastr.error(msg);
                        }
                    })
                    .catch(function () { $spinner.addClass('d-none'); });
            } else {
                $spinner.addClass('d-none');
            }
        }

        // إزالة الكوبون — متوافق مع واجهة zid.cart الجديدة
        function deleteCoupon(element) {
            var $form = element ? $(element).closest('.coupon-form') : $('.coupon-form').first();
            var $spinner = $form.find('.delete-coupon-progress');
            if (!$spinner.length) $spinner = $('.delete-coupon-progress').first();
            if (!$spinner.hasClass('d-none')) return;
            $spinner.removeClass('d-none');
            if (window.zid && window.zid.cart && typeof window.zid.cart.removeCoupons === 'function') {
                window.zid.cart.removeCoupons({ showErrorNotification: true })
                    .then(function () {
                        $spinner.addClass('d-none');
                        window.location.reload();
                    })
                    .catch(function () { $spinner.addClass('d-none'); });
            } else if (typeof zid !== 'undefined' && zid.store && zid.store.cart && typeof zid.store.cart.removeCoupon === 'function') {
                zid.store.cart.removeCoupon()
                    .then(function (response) {
                        $spinner.addClass('d-none');
                        if (response.status === 'success') window.location.reload();
                        else {
                            var msg = (response.data && response.data.message) || (window.i18n && window.i18n.sorry) || '{{ _("Sorry") }}';
                            if (typeof toastr !== 'undefined') toastr.error(msg);
                        }
                    })
                    .catch(function () { $spinner.addClass('d-none'); });
            } else {
                $spinner.addClass('d-none');
            }
        }

        $(".cities-search-input").on('keyup', function (e) {
            const searchVal = e.target.value
            const shippingCities = (cartObj.free_shipping_rule && cartObj.free_shipping_rule.shipping_cities_condition) ? cartObj.free_shipping_rule.shipping_cities_condition : [];
            const mappedCities = shippingCities.map((city) => city.name);
            let filteredCities = mappedCities.slice(0, 50).join(' ، ');
            if (searchVal.length > 2) {
              filteredCities = mappedCities.filter((name) => name.trim().toLowerCase().includes(searchVal.trim().toLowerCase())).join(' ، ');
            }
            if (filteredCities.length) {
              $(".cities-result").html(filteredCities);
            } else {
              $(".cities-result").html('{{ _('No results found') }}');
            }
        });

            // ترتيب العناصر في صفحة السلة
  function arrangeCartProducts(){
    document.querySelectorAll('.cart-product-row').forEach(function(row) {
        const imgWrapper = row.querySelector('.cart-product-col-img');
        const detailsWrapper = row.querySelector('.cart-product-col-details');
        const priceWrapper = row.querySelector('.cart-product-prices');
        const quantityWrapper = row.querySelector('.cart-products-action');
        const discountWrapper = row.querySelector('.cart-product-discount-messages');
        const deleteWrapper = row.querySelector('.cart-product-delete');

        if(!imgWrapper || !detailsWrapper || !priceWrapper || !quantityWrapper) return;

        const select = quantityWrapper.querySelector('select');
        const cartProductId = select.getAttribute('data-cart-product-id');
        const productId = select.getAttribute('data-product-id');
        const template = select.getAttribute('data-template');
        let quantity = parseInt(select.value);

        // عنصر جديد للتحكم بالكمية (بلس وماينص)
        const newQuantityDiv = document.createElement('div');
        newQuantityDiv.className = 'custom-quantity-counter';

        const minusBtn = document.createElement('button');
        minusBtn.className = 'minus-btn';
        minusBtn.type = 'button'; // مهم عشان ما يعملش submit فورم لو جوه فورم
        minusBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none">
            <path d="M20 12L4 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>`;

        const plusBtn = document.createElement('button');
        plusBtn.className = 'plus-btn';
        plusBtn.type = 'button';
        plusBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24" fill="none">
            <path d="M12 4V20M20 12H4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>`;

        const numberSpan = document.createElement('span');
        numberSpan.className = 'quantity-number';
        numberSpan.textContent = quantity;

        newQuantityDiv.appendChild(minusBtn);
        newQuantityDiv.appendChild(numberSpan);
        newQuantityDiv.appendChild(plusBtn);

        // خلي select موجود لكنه مخفي
        select.style.display = 'none';

        // نظف الـ quantityWrapper وحط العناصر الجديدة + الـ select المخفي
        quantityWrapper.innerHTML = '';
        quantityWrapper.appendChild(newQuantityDiv);
        quantityWrapper.appendChild(select);

        // التعامل مع أزرار البلس والماينص
        plusBtn.addEventListener('click', function(){
            if(quantity < 100){
                quantity++;
                numberSpan.textContent = quantity;
                select.value = quantity;
                select.dispatchEvent(new Event('change')); // إطلاق حدث تغيير
            }
        });

        minusBtn.addEventListener('click', function(){
            if(quantity > 1){
                quantity--;
                numberSpan.textContent = quantity;
                select.value = quantity;
                select.dispatchEvent(new Event('change'));
            }
        });

        // إنشاء الهيكلة الجديدة
        const customRow = document.createElement('div');
        customRow.className = 'custom-cart-row';

        const imgDiv = document.createElement('div');
        imgDiv.className = 'custom-cart-img';
        imgDiv.appendChild(imgWrapper);

        const detailsDiv = document.createElement('div');
        detailsDiv.className = 'custom-cart-details';

        const titlePriceDiv = document.createElement('div');
        titlePriceDiv.className = 'custom-cart-title-price';
        titlePriceDiv.appendChild(detailsWrapper);
        titlePriceDiv.appendChild(priceWrapper);

        const quantityDiv = document.createElement('div');
        quantityDiv.className = 'custom-cart-quantity';

        if(discountWrapper){
            quantityDiv.appendChild(discountWrapper);
        }

        quantityDiv.appendChild(quantityWrapper);

        if(deleteWrapper){
            quantityDiv.appendChild(deleteWrapper);
        }

        detailsDiv.appendChild(titlePriceDiv);
        detailsDiv.appendChild(quantityDiv);

        customRow.appendChild(imgDiv);
        customRow.appendChild(detailsDiv);

        row.innerHTML = '';
        row.appendChild(customRow);
    });

    // إظهار نص "حذف" — القالب الافتراضي لا يتضمن .delete-text فنضيفه إن لم يكن موجوداً
    var deleteLabel = (window.i18n && window.i18n.remove) ? window.i18n.remove : '{{ _("Remove") }}';
    document.querySelectorAll('.cart-product-delete a').forEach(function(link) {
        var textEl = link.querySelector('.delete-text');
        if (!textEl) {
            textEl = document.createElement('span');
            textEl.className = 'delete-text';
            textEl.setAttribute('aria-hidden', 'true');
            link.appendChild(textEl);
        }
        textEl.textContent = deleteLabel;
    });
}

    // التحقق من وجود إصدارين مختلفين (الكبسولات / كبسولات)
    function checkDifferentVersions() {
        var alertDiv = document.getElementById('different-versions-alert');
        if (!alertDiv) return;

        // البحث عن جميع عناوين المنتجات في السلة
        var productRows = document.querySelectorAll('.cart-product-row');
        if (productRows.length < 2) {
            alertDiv.classList.add('d-none');
            return;
        }

        var hasProductWithKabsoolat = false;
        var hasProductWithoutKabsoolat = false;
        var hasProductWithCapsule = false;
        var hasProductWithoutCapsule = false;

        productRows.forEach(function(row) {
            var productName = '';
            
            // البحث في h1 > a.cart-product-image-link (النص داخل الرابط)
            var titleLink = row.querySelector('.cart-product-col-details a.cart-product-image-link');
            if (titleLink) {
                productName = titleLink.textContent.trim();
            }
            
            // إذا لم نجد، نبحث في أي رابط .cart-product-image-link
            if (!productName) {
                var link = row.querySelector('.cart-product-image-link');
                if (link) {
                    productName = link.textContent.trim() || link.getAttribute('title') || '';
                }
            }
            
            // إذا لم نجد، نبحث في alt attribute للصورة
            if (!productName) {
                var img = row.querySelector('.cart-product-image');
                if (img) {
                    productName = img.getAttribute('alt') || '';
                }
            }
            
            if (!productName) return;
            
            // التحقق من وجود كلمة "كبسولات" (سواء "كبسولات" أو "الكبسولات") - العربية
            var productNameLower = productName.toLowerCase();
            if (productName.includes('كبسولات')) {
                hasProductWithKabsoolat = true;
            } else {
                hasProductWithoutKabsoolat = true;
            }
            
            // التحقق من وجود كلمة "Capsule" أو "Capsules" - الإنجليزية
            if (productNameLower.includes('capsule')) {
                hasProductWithCapsule = true;
            } else {
                hasProductWithoutCapsule = true;
            }
        });

        // إذا وجدنا منتج يحتوي على "كبسولات" وآخر لا يحتوي عليها (عربي)
        // أو منتج يحتوي على "Capsule" وآخر لا يحتوي عليها (إنجليزي)
        var shouldShowAlert = (hasProductWithKabsoolat && hasProductWithoutKabsoolat) || 
                              (hasProductWithCapsule && hasProductWithoutCapsule);
        
        if (shouldShowAlert) {
            alertDiv.classList.remove('d-none');
        } else {
            alertDiv.classList.add('d-none');
        }
    }

    // أول ما الصفحة تفتح، يرتب السلة
    document.addEventListener('DOMContentLoaded', function() {
        arrangeCartProducts();
        moveFeaturesForResponsive();
        // تأخير بسيط للتأكد من تحميل المنتجات
        setTimeout(function() {
            checkDifferentVersions();
        }, 500);
    });


          function cartProductsHtmlChanged(html, cart){
            if(cart.products_count <= 0){
                $('.cart-products-with-totals').addClass('d-none');
                $('.cart-empty').removeClass('d-none');
                return;
            }else{
                $('.cart-products-with-totals').removeClass('d-none');
                $('.cart-empty').addClass('d-none');
            }

            $('.template_for_cart_products_list').html(html);
            arrangeCartProducts();

            if(cart &&  cart.totals){
                var strCartTotlas = '';
                for(var i = 0; i < cart.totals.length; i++){
                    var cartTotal = cart.totals[i];

                    var vat_included = '';
                    if(cartTotal.code === 'total'){

                        var is_cart_total_vat_included = {% if store.settings.general.tax_settings.tax_percentage_formatted %}true{% else %}false{% endif %};
                        var local_sys_lbl_cart_includes_vat = "{{ _('Includes TAX %(percentage)s') | format(percentage=store.settings.general.tax_settings.tax_percentage_formatted) }}";

                        if(is_cart_total_vat_included){
                            vat_included = '&nbsp;<small>'+local_sys_lbl_cart_includes_vat+'</small>';
                        }

                    }


                    strCartTotlas += `
                        <div class="cart-product-row-wrapper cart-totals-row-wrapper">
                            <h3>${cartTotal.title}${vat_included}</h3>
                            <p class="${cartTotal.code === 'total' ? 'total-price-p' : ''}">
                                ${cartTotal.value_string}
                            </p>
                        </div>
                    `;
                }

                $('.cart-totals-div').html(strCartTotlas);
            }

             if(cart.free_shipping_rule){
                $('.free-shipping-rule-section').removeClass('d-none')
                $('.free-shipping-rule-message').html(cart.free_shipping_rule.subtotal_condition.status)
                $('.free-shipping-rule-progress').css('width', `${cart.free_shipping_rule.subtotal_condition.products_subtotal_percentage_from_min}%`)
                if (cart.free_shipping_rule.subtotal_condition.status === 'applied') {
                    $('.free-shipping-rule-done').removeClass('d-none')
                    $('.free-shipping-rule-read-more').addClass('d-none')
                    $('.free-shipping-rule-progress').html('{{ _("Free Shipping") }}')
                }else {
                    $('.free-shipping-rule-done').addClass('d-none')
                    $('.free-shipping-rule-read-more').removeClass('d-none')
                    $('.free-shipping-rule-progress').html(`${cart.free_shipping_rule.subtotal_condition.products_subtotal_percentage_from_min}%`)
                }
            }else{
                $('.free-shipping-rule-section').addClass('d-none')
            }


        setCartTotalAndBadge(cart);
        addDeleteProgressImage();
        moveFeaturesForResponsive();
    }

    // نقل قائمة المزايا تحت المجمل عند الشاشات <= 1200px وإعادتها عند الأكبر
    function moveFeaturesForResponsive(){
        var features = document.querySelector('.features-product');
        var totals = document.querySelector('.cart-totals');
        if(!features || !totals) return;

        // إنشاء عنصر placeholder مرة واحدة للاحتفاظ بالموقع الأصلي
        if(!features.dataset.hasPlaceholder){
            var placeholder = document.createElement('div');
            placeholder.className = 'features-product-placeholder';
            features.parentNode.insertBefore(placeholder, features);
            features.dataset.hasPlaceholder = 'true';
        }

        var isSmall = window.innerWidth <= 1200;
        var moved = features.dataset.moved === 'true';

        if(isSmall && !moved){
            totals.insertAdjacentElement('afterend', features);
            features.dataset.moved = 'true';
        } else if(!isSmall && moved){
            var ph = document.querySelector('.features-product-placeholder');
            if(ph && ph.parentNode){
                ph.parentNode.insertBefore(features, ph.nextSibling);
            }
            features.dataset.moved = 'false';
        }
    }

    // إعادة الترتيب عند تغيير حجم الشاشة
    window.addEventListener('resize', moveFeaturesForResponsive);

    </script>
