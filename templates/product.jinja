<script>
  $(document).ready(function () {
  function getMaxQuantity() {
    var $hiddenSelect = $('.select-quantity-div:first .select-quantity');
    var maxQty = $hiddenSelect.find('option').length;
    return maxQty > 0 ? maxQty : 100;
  }

  function syncAllQuantityFields(newValue) {
    $('.select-quantity-div:first .select-quantity').val(newValue);
    
    $('#product-quantity-input').val(newValue);
  }

  $('#increase-quantity').on('click', function () {
    var currentValue = parseInt($('#product-quantity-input').val()) || 1;
    var maxQuantity = getMaxQuantity();

    if (currentValue < maxQuantity) {
      syncAllQuantityFields(currentValue + 1);
    }
  });

  $('#decrease-quantity').on('click', function () {
    var currentValue = parseInt($('#product-quantity-input').val()) || 1;

    if (currentValue > 1) {
      syncAllQuantityFields(currentValue - 1);
    }
  });

  $(document).on('DOMSubtreeModified', '.select-quantity', function() {
    var $input = $('#product-quantity-input');
    var currentInputValue = parseInt($input.val()) || 1;
    var newMaxQuantity = getMaxQuantity();
    if (currentInputValue > newMaxQuantity) {
      syncAllQuantityFields(newMaxQuantity);
    }
  });

  syncAllQuantityFields(1);
});
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const labels = document.querySelectorAll("#product-variants-options label");
    labels.forEach(label => {
      if (!label.querySelector("span")) {
        const text = label.textContent.trim();
        label.textContent = "";
        const span = document.createElement("span");
        span.textContent = text;
        label.appendChild(span);
      }
    });

    const variants = {{ product.variants | tojson | safe }};
    const options = document.querySelectorAll("#product-variants-options ul li");

    options.forEach((li, index) => {
      const variant = variants[index];
      if (!variant) return;

      const price = variant.price;
      const salePrice = variant.sale_price;
      const formattedPrice = variant.formatted_price;
      const formattedSalePrice = variant.formatted_sale_price;

      li.dataset.price = price;
      li.dataset.salePrice = salePrice || '';
      li.dataset.variantId = variant.id;

      if (variant.images && variant.images.length > 0) {
        const imageUrl = variant.images[0].image.small || variant.images[0].image.thumbnail;
        let imgEl = li.querySelector('img.variant-image');
        if (!imgEl) {
          imgEl = document.createElement('img');
          imgEl.className = 'variant-image';
          imgEl.loading = 'lazy';
          li.insertBefore(imgEl, li.firstChild);
        }
        imgEl.src = imageUrl;
        imgEl.alt = variant.name || '';
      }

      if (!li.querySelector('em')) {
        const em = document.createElement('em');
        li.insertBefore(em, li.firstChild);
      }

      let priceSpan = li.querySelector('.variant-price');
      if (!priceSpan) {
        priceSpan = document.createElement('span');
        priceSpan.className = 'variant-price';
        li.appendChild(priceSpan);
      }

      if (salePrice && salePrice < price) {
        priceSpan.innerHTML = `
          <span class="old-price">
            ${formattedPrice.trim()}
          </span>
          <span class="new-price">
            ${formattedSalePrice.trim()}
          </span>
        `;
      } else {
        priceSpan.innerHTML = `
          <span class="new-price">${formattedPrice.trim()}</span>
        `;
      }
    });
  });
</script>


<script>
  document.addEventListener("DOMContentLoaded", function () {
    const metafields = {{ product.metafields | tojson | safe }};
    if (!Array.isArray(metafields)) return;

    const currentLang = "{{ session.lang }}" || "ar";

    // ===== Inject text metafields =====
    function injectMetaContent(slug, selector) {
      const meta = metafields.find((m) => m.slug === slug);
      if (!meta || !meta.value) return false;
      const content = meta.value[currentLang] || meta.value.ar || meta.value.en;
      if (!content) return false;
      const target = document.querySelector(selector);
      if (target) target.innerHTML = content;
      return true;
    }

    const hasMini = injectMetaContent("mini-desc-product", ".meta-mini");
    const hasCompareTitle = injectMetaContent("compare-title", ".compare-title");
    const hasCompareTable = injectMetaContent("compare-table", ".compare-table");
    const hasVideosTitle = injectMetaContent("reviews-title", ".videos-title");

    // ===== FAQs Section =====
    let hasFaqs = false;
    const faqsTitleMeta = metafields.find((m) => m.slug === "questions-title");
    const faqsListMeta = metafields.find((m) => m.slug === "questions-list");

    if (faqsTitleMeta && faqsTitleMeta.value) {
      const title =
        faqsTitleMeta.value[currentLang] ||
        faqsTitleMeta.value.ar ||
        faqsTitleMeta.value.en;
      if (title) document.querySelector(".faqs-title").textContent = title;
    }

    if (faqsListMeta && faqsListMeta.value) {
      const faqsData = faqsListMeta.value.cells || [];
      const faqsBox = document.querySelector("#faqs-box");

      faqsData.forEach((row, index) => {
        const question =
          row[0]?.value?.[currentLang] ||
          row[0]?.value?.ar ||
          row[0]?.value?.en ||
          "";
        const answer =
          row[1]?.value?.[currentLang] ||
          row[1]?.value?.ar ||
          row[1]?.value?.en ||
          "";

        if (!question && !answer) return;

        const item = document.createElement("div");
        item.className = "accordion-item";

        item.innerHTML = `
          <h2 class="accordion-header">
            <button class="accordion-button collapsed"
              type="button" data-bs-toggle="collapse"
              data-bs-target="#faq-collapse-${index}"
              aria-expanded="false"
              aria-controls="faq-collapse-${index}">
              <span>${index + 1 < 10 ? "0" + (index + 1) : index + 1}</span>
              ${question}
            </button>
          </h2>
          <div id="faq-collapse-${index}"
            class="accordion-collapse collapse"
            data-bs-parent="#faqs-box">
            <div class="accordion-body">${answer}</div>
          </div>
        `;
        faqsBox.appendChild(item);
        hasFaqs = true;
      });
    }

    // ===== Reviews / Videos Section =====
    let hasVideos = false;
    const reviewsMeta = metafields.find((m) => m.slug === "reviews-ratings");
    const container = document.querySelector(".tp-videos-items");

    if (reviewsMeta && reviewsMeta.value && container) {
      const reviewsData = reviewsMeta.value?.cells || [];

      reviewsData.forEach((row) => {
        const name =
          row[0]?.value?.[currentLang] ||
          row[0]?.value?.ar ||
          row[0]?.value?.en ||
          "";
        const reviewText =
          row[1]?.value?.[currentLang] ||
          row[1]?.value?.ar ||
          row[1]?.value?.en ||
          "";
        const imgSrc = row[2]?.value?.full_size || row[2]?.value?.medium || "";
        const videoSrc = row[3]?.value?.url || "";

        if (!name && !reviewText && !videoSrc && !imgSrc) return;

        const slide = document.createElement("div");
        slide.className = "swiper-slide";

        slide.innerHTML = `
          <div class="video-story">
            ${
              videoSrc
                ? `
                <video width="100%" loop muted playsinline>
                  <source src="${videoSrc}" type="video/mp4">
                </video>
                <button class="play-video" title="Play / Pause">
                  ${document.querySelector("#icon-play").outerHTML}
                </button>
                <button class="volume-toggle" title="Toggle Sound">
                  <span class="icon-mute">${
                    document.querySelector("#icon-mute").outerHTML
                  }</span>
                  <span class="icon-unmute" style="display:none;">${
                    document.querySelector("#icon-unmute").outerHTML
                  }</span>
                </button>
              `
                : imgSrc
                ? `<img loading="lazy" width="100%" height="550" src="${imgSrc}" alt="${name}">`
                : ""
            }
            ${
              name || reviewText
                ? `
                <div class="review-box">
                  ${name ? `<h3>${name}</h3>` : ""}
                  ${document.querySelector("#icon-stars").outerHTML}
                  ${reviewText ? `<p>${reviewText}</p>` : ""}
                </div>
              `
                : ""
            }
          </div>
        `;
        container.appendChild(slide);
        hasVideos = true;
      });
    }

    const videoStories = document.querySelectorAll(".video-story");

    videoStories.forEach((story) => {
      const video = story.querySelector("video");
      const playBtn = story.querySelector(".play-video");
      const volumeBtn = story.querySelector(".volume-toggle");
      const reviewBox = story.querySelector(".review-box");
      const muteIcon = volumeBtn?.querySelector(".icon-mute");
      const unmuteIcon = volumeBtn?.querySelector(".icon-unmute");

      if (video) {
        if (volumeBtn) volumeBtn.style.display = "none";

        if (muteIcon && unmuteIcon) {
          muteIcon.style.display = video.muted ? "block" : "none";
          unmuteIcon.style.display = video.muted ? "none" : "block";
        }

        video.addEventListener("click", () =>
          toggleVideo(video, playBtn, volumeBtn, reviewBox)
        );

        if (playBtn) {
          playBtn.addEventListener("click", (e) => {
            e.stopPropagation();
            toggleVideo(video, playBtn, volumeBtn, reviewBox);
          });
        }

        video.addEventListener("pause", () => {
          if (playBtn) playBtn.style.display = "block";
          if (volumeBtn) volumeBtn.style.display = "none";
          if (reviewBox) reviewBox.style.display = "block";
        });
        video.addEventListener("play", () => {
          if (playBtn) playBtn.style.display = "none";
          if (volumeBtn) volumeBtn.style.display = "block";
          if (reviewBox) reviewBox.style.display = "none";
        });
      }

      if (video && volumeBtn) {
        volumeBtn.addEventListener("click", (e) => {
          e.stopPropagation();
          video.muted = !video.muted;
          muteIcon.style.display = video.muted ? "block" : "none";
          unmuteIcon.style.display = video.muted ? "none" : "block";
        });
      }

      function toggleVideo(video, playBtn, volumeBtn, reviewBox) {
        videoStories.forEach((other) => {
          const otherVideo = other.querySelector("video");
          const otherPlay = other.querySelector(".play-video");
          const otherVolume = other.querySelector(".volume-toggle");
          if (otherVideo && otherVideo !== video) {
            const otherBox = other.querySelector(".review-box");
            otherVideo.pause();
            otherPlay?.classList.remove("is-playing");
            if (otherPlay) otherPlay.style.display = "block";
            if (otherVolume) otherVolume.style.display = "none";
            if (otherBox) otherBox.style.display = "block";
          }
        });

        if (video.paused) {
          video.play();
          playBtn?.classList.add("is-playing");
          if (volumeBtn) volumeBtn.style.display = "block";
          if (reviewBox) reviewBox.style.display = "none";
        } else {
          video.pause();
          playBtn?.classList.remove("is-playing");
          if (volumeBtn) volumeBtn.style.display = "none";
          if (reviewBox) reviewBox.style.display = "block";
        }
      }
    });

    function isInViewport(element) {
      const rect = element.getBoundingClientRect();
      return rect.top < window.innerHeight && rect.bottom > 0;
    }

    window.addEventListener("scroll", () => {
      document.querySelectorAll(".video-story video").forEach((video) => {
        const parent = video.closest(".video-story");
        const playBtn = parent.querySelector(".play-video");
        const volumeToggle = parent.querySelector(".volume-toggle");
        const reviewBox = parent.querySelector(".review-box");

        if (!isInViewport(video) && !video.paused) {
          video.pause();
          playBtn.classList.remove("hidden");
          playBtn.style.display = "block";
          volumeToggle.style.display = "none";
          if (reviewBox) reviewBox.style.display = "block";
        }
      });
    });

    if (!hasMini)
      document.querySelector(".meta-mini")?.closest(".container")?.remove();
    if (!hasCompareTitle && !hasCompareTable)
      document.querySelector(".compare-part")?.remove();
    if (!hasVideos && !hasVideosTitle)
      document.querySelector(".videos-part")?.remove();
    if (!hasFaqs) document.querySelector(".faqs-part")?.remove();

    if (hasVideos) {
      setTimeout(() => {
        initSlickSlider();
      }, 500);
    }

    function initSlickSlider() {
      var arrowNextClass =
        window.appDirection === "ltr"
          ? "icon-keyboard_arrow_right"
          : "icon-keyboard_arrow_left";
      var arrowPrevClass =
        window.appDirection === "ltr"
          ? "icon-keyboard_arrow_left"
          : "icon-keyboard_arrow_right";
      var $slider = $(".tp-videos-items");

      if ($slider.length && !$slider.hasClass("slick-initialized")) {
        $slider.slick({
          slidesToScroll: 4,
          slidesToShow: 4,
          infinite: true,
          autoplay: true,
          autoplaySpeed: 5000,
          arrows: true,
          dots: true,
          rtl: !(window.appDirection === "ltr"),
          nextArrow:
            '<button class="slick-next slick-arrow" aria-label="Next" type="button"><span class="' +
            arrowNextClass +
            '"></span></button>',
          prevArrow:
            '<button class="slick-prev slick-arrow" aria-label="Previous" type="button"><span class="' +
            arrowPrevClass +
            '"></span></button>',
          responsive: [
          {
            breakpoint: 992,
            settings: {
              slidesToShow: 3,
              centerMode: true,
              centerPadding: '60px',
            }
          },
          {
            breakpoint: 768,
            settings: {
              slidesToShow: 2,
              centerMode: true,
              centerPadding: '50px',
            }
          },
          {
            breakpoint: 500,
            settings: {
              slidesToShow: 2,
              centerMode: true,
              centerPadding: '20px',
            }
          },
          {
            breakpoint: 375,
            settings: {
              slidesToShow: 1,
              centerMode: true,
              centerPadding: '30px',
            }
          }
        ]
        });
      }
    }
  });
</script>

<script>
$(function() {
  var items = $(".product-info-toggle .info-item"),
      index = -1;

  function showNext() {
    index++;
    items.eq(index % items.length)
      .fadeIn(400)
      .delay(3000)
      .fadeOut(400, showNext);
  }

  if (items.length > 1) {
    items.hide();
    showNext();
  } else {
    items.show();
  }
});

document.addEventListener("DOMContentLoaded", function () {
  var loyaltyLong = {{ _("Points earned by purchasing this product") | tojson }};
  var loyaltyShort = {{ _("Points earned") | tojson }};
  const interval = setInterval(() => {
    document.querySelectorAll('.loyalty-points-products-section p').forEach(p => {
      if (p.textContent.trim().indexOf(loyaltyLong) !== -1) {
        p.textContent = loyaltyShort;
        clearInterval(interval);
      }
    });
  }, 200);
});

</script>



{% endblock %}

