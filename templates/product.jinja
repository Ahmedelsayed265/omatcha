            <img loading="lazy" width="26" height="26" class="lazy-img" src="{{ image_url(item.image) }}" alt="">
          {% endif %}
          {{ item.title }}
        </a>
      {% endfor %}
    </div>
    <div class="tp-marquee">
      {% for item in (bar_list or []) %}
        <a href="{% if item.url %}{{ item.url }}{% else %}javascript:;{% endif %}" style="color: {{ item.text_color }};">
          {% if item.image %}
            <img loading="lazy" width="26" height="26" class="lazy-img" src="{{ image_url(item.image) }}" alt="">
          {% endif %}
          {{ item.title }}
        </a>
      {% endfor %}
    </div>
  </div>
</div>
{% endif %}

  <div class="container">
    <div class="tp-product-details-tab-nav tp-tab">
