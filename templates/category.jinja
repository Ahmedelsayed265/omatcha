  {# products section #}
  <section class="store-one-products s-block" section-id="store-one-products">
    <div class="container">
      <div class="tp-section-title-wrapper mb-4">
        <h2 class="tp-section-title">{{ settings.store_two_products_section_title }}</h2>
      </div>

      <div class="products_swiper swiper">
        <div class="swiper-wrapper">
          {% for product in products.results %}
          <div class="swiper-slide">
            {% set product=product %}{% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
          </div>
