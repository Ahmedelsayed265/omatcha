      </div>
      
      <script>
        document.addEventListener("DOMContentLoaded", function () {
          if (typeof Swiper !== 'undefined') {
            new Swiper('.brands_swiper', {
              slidesPerView: 3,
              spaceBetween: 16,
              loop: true,
              breakpoints: {
                576: {
                  slidesPerView: 3,
                  spaceBetween: 20,
                },
                768: {
                  slidesPerView: 4,
                  spaceBetween: 24,
                },
                1024: {
                  slidesPerView: 5,
