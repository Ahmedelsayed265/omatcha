          {% if settings.store_two_banner_with_content_btn_text %}
            <a href="{{ settings.store_two_banner_with_content_btn_url }}" class="tp-btn">
              {{ settings.store_two_banner_with_content_btn_text }}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.99984 14.6666C4.31794 14.6666 1.33317 11.6818 1.33317 7.99992C1.33317 4.31802 4.31794 1.33325 7.99984 1.33325C11.6817 1.33325 14.6665 4.31802 14.6665 7.99992C14.6665 11.6818 11.6817 14.6666 7.99984 14.6666Z" stroke="#131313" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.3335 8H6.3335" stroke="#131313" stroke-linecap="round" stroke-linejoin="round"/>
