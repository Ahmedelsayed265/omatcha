{% extends "layout.jinja" %}

{% block header %}
{% include 'header.jinja' %}
{% endblock %}

{% block top_links %}
<link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
{% endblock %}

{% block main_content %}

{%if category.slug == "store-one" %}
  {# Store One Hero Section #}
  <section class="store-one-hero">
    {% if settings.store_one_hero_image or settings.store_one_hero_mobile_image %}
      <picture>
        {% if settings.store_one_hero_mobile_image %}
        <source media="(max-width: 767px)" srcset="{{ image_url(settings.store_one_hero_mobile_image) }}">
        {% endif %}
        {% if settings.store_one_hero_image %}
        <source media="(min-width: 768px)" srcset="{{ image_url(settings.store_one_hero_image) }}">
        {% endif %}
        <img loading="lazy" width="1800" height="450" class="lazy-img" data-src="{{ image_url(settings.store_one_hero_image) }}"
          alt="banner">
      </picture>
    {% endif %}

    <div class="store-one-hero-overlay">
      <div class="container">
        <div class="tp-hero-content">
          {% if settings.store_one_hero_subtitle %}
            <span>{{ settings.store_one_hero_subtitle }}</span>
          {% endif %}

          {% if settings.store_one_hero_title %}
            <h1>{{ settings.store_one_hero_title }}</h1>
          {% endif %}

          {% if settings.store_one_hero_des %}
            <p>{{ settings.store_one_hero_des }}</p>
          {% endif %}
    
          {% if settings.store_one_hero_btn_text and settings.store_one_hero_url %}
            <a href="{{ settings.store_one_hero_url }}" class="tp-btn">{{ settings.store_one_hero_btn_text }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  {# Store One categories Section #}
  <section class="store-one-categories s-block">
    <div class="container">
      <div class="tp-section-title-wrapper mb-4">
        <h2 class="tp-section-title">{{ settings.store_one_cat_section_title }}</h2>
      </div>

      <div class="store-one-cat-slider swiper-container">
        <div class="swiper-wrapper">
          {% for categoryItem in safeget(settings, 'store_one_cat_section_categories', []) %}
          <div class="swiper-slide">
            <div class="store-one-cat-item">
              {% if categoryItem.image %}
              <div class="cat-thumb">
                <a href="{{ categoryItem.url }}">
                  <img loading="lazy" src="{{ image_url(categoryItem.image, { w: 235, q: 100, f:'auto' }) }}"
                    alt="{{ categoryItem.title }}">
                </a>
              </div>
              {% endif %}
              <div class="cat-content">
                <h3 class="cat-title">
                  <a href="{{ categoryItem.url }}">{{ categoryItem.title }}</a>
                </h3>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

  {# products section #}
  <section class="store-one-products s-block" section-id="store-one-products">
    <div class="container">
      <div class="tp-section-title-wrapper mb-4">
        <h2 class="tp-section-title">{{ settings.store_one_products_section_title }}</h2>
      </div>

      <div class="products_swiper swiper">
        <div class="swiper-wrapper">
          {% for product in products.results %}
          <div class="swiper-slide">
            {% set product=product %}{% set index=loop.index0 %}{% include 'components/product-card.jinja' %}
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    <script>
      document.addEventListener("DOMContentLoaded", function () {
        if (typeof Swiper !== 'undefined') {
          new Swiper('.products_swiper', {
            slidesPerView: 1.5,
            spaceBetween: 16,
            loop: true,
            breakpoints: {
              576: {
                slidesPerView: 2,
                spaceBetween: 20,
              },
              768: {
                slidesPerView: 3,
                spaceBetween: 24,
              },
              1024: {
                slidesPerView: 4,
                spaceBetween: 30,
              },
            },
          });
        }
      });
    </script>
  </section>

  {# banner with features section #}
  <section class="s-block banner_with_features">
    <div class="container">
      <div class="row">
        <div class="col-lg-7 p-2">
          <div class="banner_with_features_content">
            <h2>{{ settings.store_one_banner_with_features_title }}</h2>
            <p>{{ settings.store_one_banner_with_features_des }}</p>

            <div class="grid_features">
              {% for feature in safeget(settings, 'store_one_banner_with_features_features', []) %}
              <div class="feature-item">
                <img src="{{ image_url(feature.icon) }}" loading="lazy" alt="">
                <h6>{{ feature.title }}</h6>
                <p>{{ feature.description }}</p>
              </div>
              {% endfor %}
            </div>
          </div>
        </div>

        <div class="col-lg-5 p-2">
          <div class="banner_with_features_image">
            <img src="{{ image_url(settings.store_one_banner_with_features_image) }}" loading="lazy" alt="">
          </div>
        </div>
      </div>
    </div>
  </section>

  {# store features #}
  <section class="s-block store_features">
    <div class="container">
      <div class="tp-section-title-wrapper mb-4">
        <h2 class="tp-section-title">{{ settings.store_one_features_title }}</h2>
      </div>

      <div class="features_wrapper">
        {% for feature in settings.store_one_features_features %}
        <div class="feature_item">
          <div class="feature_icon">
            <img src="{{ image_url(feature.icon) }}" loading="lazy" alt="">
          </div>

          <div class="feature_content">
            <h6>{{ feature.title }}</h6>
            <p>{{ feature.description }}</p>
          </div>
        </div>
        {% endfor %}
      </div>
    </div>
  </section>

  {# banner with content #}
  <section class="s-block banner_with_content">
    <div class="container">
      <div class="banner_with_content_image">
        <img src="{{ image_url(settings.store_one_banner_with_content_image) }}" loading="lazy" alt="">
        
        <div class="banner_with_content_content">
          <h2>{{ settings.store_one_banner_with_content_title }}</h2>
          <p>{{ settings.store_one_banner_with_content_des }}</p>

          {% if settings.store_one_banner_with_content_btn_text %}
            <a href="{{ settings.store_one_banner_with_content_btn_url }}" class="tp-btn">
              {{ settings.store_one_banner_with_content_btn_text }}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M7.99984 14.6666C4.31794 14.6666 1.33317 11.6818 1.33317 7.99992C1.33317 4.31802 4.31794 1.33325 7.99984 1.33325C11.6817 1.33325 14.6665 4.31802 14.6665 7.99992C14.6665 11.6818 11.6817 14.6666 7.99984 14.6666Z" stroke="#131313" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M10.3335 8H6.3335" stroke="#131313" stroke-linecap="round" stroke-linejoin="round"/>
                <path d="M7.6665 10L5.6665 8L7.6665 6" stroke="#131313" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  {# influencers experiences section #}
  <section class="s-block influencers_experiences" section-id="influencers_experiences">
    <div class="container">
      <div class="tp-section-title-wrapper mb-4">
        <h2 class="tp-section-title">{{ settings.store_one_influencers_experiences_title }}</h2>
      </div>

      <div class="influencers_swiper swiper">
        <div class="swiper-wrapper">
          {% for influencer in safeget(settings, 'store_one_influencers_experiences_influencers', []) %}
          <div class="swiper-slide">
            <div class="video-story">
              {% if influencer.video %}
                <video width="100%" loop muted playsinline>
                  <source src="{{ influencer.video }}" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              {% else %}
                <img loading="lazy" width="100%" height="550" src="{{ image_url(influencer.image) }}" alt="{{ influencer.name }}">
              {% endif %}
              
              <div class="review-box">
                <h3>{{ influencer.name }}</h3>
                
                {% if influencer.product %}
                  {% if influencer.product.is_infinite == false and influencer.product.quantity <= 0 %} 
                    <a class="btn-order-product" disabled>
                      {{ _('Out of Stock') }}
                    </a>
                  {% elif ( influencer.product.has_options or influencer.product.has_fields ) %}
                    <a class="btn-order-product" href="/products/{{ influencer.product.slug }}">
                      {{ _('Order Product') }}
                    </a>
                  {% else %}
                    <button type="button" class="btn-order-product" onclick="productCartAddToCart(this,'{{ influencer.product.id }}')" aria-label="AddToCart">
                      {{ _('Order Product') }}
                    </button>
                  {% endif %}
                {% endif %}
              </div>

              <div class="play-video" title="play-video">
                <svg width="17" height="23" viewBox="0 0 17 23" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M15.4324 9.7218C16.4657 10.5225 16.4657 12.083 15.4324 12.8837L3.93296 21.7942C2.61872 22.8125 0.707951 21.8758 0.707951 20.2132L0.707952 2.39223C0.707952 0.729617 2.61872 -0.207059 3.93296 0.8113L15.4324 9.7218Z" fill="white" fill-opacity="0.8"></path></svg>
              </div>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>
    
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        if (typeof Swiper !== 'undefined') {
          const influSwiper = new Swiper('.influencers_swiper', {
            slidesPerView: 1.2,
            spaceBetween: 15,
            loop: false,
            breakpoints: {
              576: { slidesPerView: 2, spaceBetween: 20 },
              768: { slidesPerView: 3, spaceBetween: 24 },
              1024: { slidesPerView: 4, spaceBetween: 30 }
            }
          });

          // Video handling
          const videoItems = document.querySelectorAll('.influencers_experiences .video-story');
          videoItems.forEach(item => {
            const video = item.querySelector('video');
            const playIcon = item.querySelector('.play-video');
            if (video) {
              item.addEventListener('mouseenter', () => {
                video.play();
                if (playIcon) playIcon.style.opacity = '0';
              });
              item.addEventListener('mouseleave', () => {
                video.pause();
                if (playIcon) playIcon.style.opacity = '1';
              });
              // Simple mobile toggle
              item.addEventListener('click', () => {
                if (video.paused) {
                  video.play();
                  if (playIcon) playIcon.style.opacity = '0';
                } else {
                  video.pause();
                  if (playIcon) playIcon.style.opacity = '1';
                }
              });
            }
          });
        }
      });
    </script>
  </section>

{%elif category.slug == "store-two" %}
