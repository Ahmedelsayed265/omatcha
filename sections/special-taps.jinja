{% if not settings.hide_element %}
<section class="tp-special-tabs-products s-block" section-id="{{ sectionId }}">
  <div class="container pd-0-first">
    <div class="tp-tabs">
      {% for tab in settings.tabs %}
          <div class="tp-tab-media {% if loop.first %}active{% endif %}" data-tab-media="tab-{{ sectionId }}-{{ loop.index }}">
            {% if tab.video %}
              <video width="1670" height="670" autoplay muted loop playsinline>
                <source src="{{ tab.video }}" type="video/mp4">
                متصفحك لا يدعم عرض الفيديو.
              </video>
            {% elif tab.image or tab.mobile_image %}
              <picture>
                {% if tab.mobile_image %}
                  <source media="(max-width: 767px)" srcset="{{ image_url(tab.mobile_image) }}">
                {% endif %}
                {% if tab.image %}
                  <source media="(min-width: 768px)" srcset="{{ image_url(tab.image) }}">
                {% endif %}
                <img loading="lazy" width="1670" height="670" data-src="{{ image_url(tab.image) }}" alt="{{ tab.label }}">
              </picture>
            {% endif %}
            <div class="tp-tab-media-overlay">
              <div class="container">
                <h2>{{ tab.title }}</h2>
                <p>{{ tab.subtitle }}</p>
                {% if tab.button_url %}
                <a href="{{ tab.button_url }}" class="tp-tab-media-button">{{ tab.button_text }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      <ul class="tp-tabs-list">
        {% for tab in settings.tabs %}
          <li class="tp-tab-item {% if loop.first %}active{% endif %}" data-tab="tab-{{ sectionId }}-{{ loop.index }}">
            {{ tab.label }}
          </li>
        {% endfor %}
      </ul>
    </div>
  </div>

    <div class="container">
      <div class="tp-tabs-content">
        {% for tab in settings.tabs %}
          {# دعم كلٍ من category.products.results و category.products، مع حد ثابت 12 مثل القسم الآخر #}
          {% set tab_products = safeget(tab, "category.products.results", []) or safeget(tab, "category.products", []) %}
          <div class="tp-tab-content {% if loop.first %}active{% endif %}" data-tab-content="tab-{{ sectionId }}-{{ loop.index }}" style="{% if not loop.first %}display: none;{% endif %}">
            <div class="tp-products-swiper">
                {% for product in tab_products[:12] %}
                  <div class="swiper-slide">
                    {% set index = loop.index0 %}
                    {% include 'components/product-card.jinja' %}
                  </div>
                {% endfor %}
            </div>
            {% if tab.category and tab.category.url %}
              <a class="href" href="{{ tab.category.url }}">
              {{ _('View all') }}
            <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
              <g fill="none" class="stroke-current" stroke-width="1.5" stroke-linejoin="round" stroke-miterlimit="10">
                <circle class="arrow-icon--circle" cx="16" cy="16" r="15.12"></circle>
                <path class="arrow-icon--arrow" d="M16.14 9.93L22.21 16l-6.07 6.07M8.23 16h13.98"></path>
              </g>
            </svg>
          </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>

<style>
.tp-tab-content {
  display: none;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.2s ease, visibility 0.2s ease;
}

.tp-tab-content.active {
  display: block !important;
  opacity: 1;
  visibility: visible;
}

.tp-tab-media {
  display: none;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.tp-tab-media.active {
  display: block;
  opacity: 1;
}

@media (max-width: 991px) {
  .tp-special-tabs-products .tp-products-swiper {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 15px !important;
    padding: 0;
  }
  .tp-special-tabs-products .tp-products-swiper .swiper-slide {
    width: 100% !important;
    margin: 0 !important;
    display: block !important;
  }
  .tp-special-tabs-products .slick-dots {
    display: none !important;
  }
}

@media (max-width: 480px) {
  .tp-special-tabs-products .tp-products-swiper {
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 10px !important;
  }
}
</style>

<script>
document.addEventListener("DOMContentLoaded", function () {
  var section = document.querySelector('[section-id="{{ sectionId }}"]');
  if (!section) return;

  const arrowNextClass = (window.appDirection === 'ltr') ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';
  const arrowPrevClass = (window.appDirection === 'ltr') ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';

  function initSlickSlider(slider) {
    if (!slider || slider.querySelectorAll('.product-box').length === 0) return;

    const $slider = $(slider);
    if ($slider.hasClass("slick-initialized")) {
      $slider.slick("unslick");
    }

    var twoRows = {{ 'true' if settings.display_two_rows else 'false' }} === true;

    if (slider.querySelectorAll('.product-box').length === 0) return;
    
    $slider.slick({
      slidesToShow: 4,
      slidesToScroll: 4,
      infinite: false,
      autoplay: true,
      autoplaySpeed: 3000,
      arrows: true,
      dots: true,
      rtl: !(window.appDirection === 'ltr'),
      nextArrow: '<button class="slick-next slick-arrow" aria-label="Next" type="button"><span class="' + arrowNextClass + '"></span></button>',
      prevArrow: '<button class="slick-prev slick-arrow" aria-label="Previous" type="button"><span class="' + arrowPrevClass + '"></span></button>',
      responsive: [
        { breakpoint: 1024, settings: { slidesToShow: 3, slidesToScroll: 3 } },
        { breakpoint: 992, settings: "unslick" }
      ]
    });
  }

  function attachTabsBehavior() {
    const tabs = section.querySelectorAll(".tp-tab-item");
    const tabContents = section.querySelectorAll(".tp-tab-content");
    const tabMedias = section.querySelectorAll(".tp-tab-media");

    tabContents.forEach(function (content) {
      const slider = content.querySelector(".tp-products-swiper");
      if (slider && !$(slider).hasClass("slick-initialized") && content.classList.contains("active")) {
        initSlickSlider(slider);
      }
    });

    tabs.forEach(function (tab) {
      tab.addEventListener("click", function () {
        const target = this.getAttribute("data-tab");

        tabs.forEach(function (t) { t.classList.remove("active"); });
        tabContents.forEach(function (c) {
          c.classList.remove("active");
          c.style.display = "none";
        });
        tabMedias.forEach(function (m) { m.classList.remove("active"); });

        this.classList.add("active");

        const targetContent = section.querySelector('[data-tab-content="' + target + '"]');
        const targetMedia = section.querySelector('[data-tab-media="' + target + '"]');

        if (targetContent) {
          targetContent.style.display = "block";
          requestAnimationFrame(function () {
            targetContent.classList.add("active");
            const slider = targetContent.querySelector(".tp-products-swiper");
            if (slider) {
              if (!$(slider).hasClass("slick-initialized")) {
                initSlickSlider(slider);
              } else {
                $(slider).slick("setPosition");
              }
            }
          });
        }
        if (targetMedia) {
          targetMedia.classList.add("active");
        }
      });
    });
  }

  var forceImmediate = {{ 'true' if store.editing_mode else 'false' }};

  if (!forceImmediate && 'IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function (entries, obs) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) {
          attachTabsBehavior();
          obs.unobserve(entry.target);
        }
      });
    }, { rootMargin: '200px 0px' });

    observer.observe(section);
  } else {
    attachTabsBehavior();
  }
});
</script>
</section>
{% endif %}