{% if not settings.hide_element %}
	<section class="tp-informative-container s-block" section-id="{{ sectionId }}">
		<div class="container">
			<div class="tp-title-section">
				{% if settings.title %}
					<h3>{{ settings.title }}</h3>
				{% endif %}
			</div>

		{% if 'informative_box' in settings %}
			{% set informative_box = settings.informative_box %}
			{% if informative_box is callable %}
				{% set informative_box = informative_box() %}
			{% endif %}
		{% else %}
			{% set informative_box = [] %}
		{% endif %}
		{% if informative_box is not iterable %}
			{% set informative_box = [] %}
		{% endif %}
		{% set right_items = informative_box[:2] %}
		{% set left_items = informative_box[2:4] %}

			<div class="tp-informative">
				<div class="right-section">
					{% for item in right_items %}
						{% if item.title or item.description or item.image %}
							<div class="informative-box">
								<div class="informative-text">
									{% if item.title %}
										<h3>{{ item.title }}</h3>
									{% endif %}
									{% if item.description %}
										<p>{{ item.description }}</p>
									{% endif %}
								</div>
								{% if item.image %}
									<img loading="lazy" width="60" height="60" class="lazy-img" data-src="{{ item.image }}" alt="{{ item.title }}">
								{% endif %}
							</div>
						{% endif %}
					{% endfor %}
				</div>

				<div class="center-image">
					{% if settings.main_image %}
						<img loading="lazy" width="300" height="500" class="lazy-img" data-src="{{ settings.main_image }}" alt="">
					{% endif %}
				</div>

				<div class="left-section">
					{% for item in left_items %}
						{% if item.title or item.description or item.image %}
							<div class="informative-box">
								<div class="informative-text">
									{% if item.title %}
										<h3>{{ item.title }}</h3>
									{% endif %}
									{% if item.description %}
										<p>{{ item.description }}</p>
									{% endif %}
								</div>
								{% if item.image %}
									<img loading="lazy" width="60" height="60" class="lazy-img" data-src="{{ item.image }}" alt="{{ item.title }}">
								{% endif %}
							</div>
						{% endif %}
					{% endfor %}
				</div>
			</div>
		</div>
	</section>
{% endif %}