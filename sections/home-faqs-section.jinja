{% if not settings.hide_element %}
{% set bg_color = settings.details_bg if settings.details_bg else '#ffffff' %}
<section class="tp-faqs s-block" section-id="{{ sectionId }}" style="background-color: {{ bg_color }};">
  <div class="container">
    <div class="tp-title-section">
      {% if settings.details_title %}
        <h3>{{ settings.details_title }}</h3>
      {% endif %}
      {% if settings.details_desc %}
        <p>{{ settings.details_desc }}</p>
      {% endif %}
    </div>
    <div class="faqs-box" id="faqs-box">
      {% if settings.faqs_store_features %}
        {% for faq in settings.faqs_store_features %}
          <div class="accordion-item" >
            <h2 class="accordion-header">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapse-{{ key }}" aria-expanded="false" aria-controls="collapse-{{ key }}">
                <span>{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
                {{ faq.title }}
              </button>
            </h2>
            <div id="collapse-{{ key }}" class="accordion-collapse collapse" data-bs-parent="#faqs-box">
              <div class="accordion-body">
                {{ faq.answer }}
              </div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>
{% endif %}