{% if not settings.hide_element %}
<section class="tp-feature-area s-block" section-id="{{ sectionId }}">
  <div class="container">
    <div class="tp-title-section">
      {% if settings.title %}
        <h3 >{{ settings.title }}</h3>
      {% endif %}
    </div>
    <div class="tp-feature-items">
    {% set features = safeget(settings, 'store_features', []) %}
      {% for feature in features %}
        <div class="feature-box" >
          <div class="icon">
            <img loading="lazy" width="64" height="65" class="lazy-img" data-src="{{ image_url(feature.image) }}"  alt="">
          </div>
          <div class="content">
            <h3 class="title">{{ feature.title }}</h3>
            <p>{{ feature.sub_title or feature.desc}}</p>
          </div>
        </div>
        {% endfor %}
    </div>
  </div>
</section> 
{% endif %}