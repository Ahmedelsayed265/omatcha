{% if not settings.hide_element %}
<section class="tp-product-card s-block {% if settings.show_in_app_only %}d-none{% endif %}" style="background: {{ settings.background_color }};" section-id="{{ sectionId }}">
	<div class="container">
    <div class="tp-title-section">
      {% if settings.title %}
        <h3>{{ settings.title }}</h3>
      {% endif %}
    </div>

		<div>
			<div class="products-grid">
				{# تجنّب division by zero: جلب القائمة بـ safeget ثم التقطيع #}
				{% set product_list = safeget(settings, 'products.products', []) or safeget(settings, 'products.results', []) %}
				{% for product in product_list[:12] %}
					{% set index = loop.index0 %}
					{% include 'components/product-card.jinja' %}
				{% endfor %}
      </div>
		</div>
    			{% if settings.display_more and settings.more_text and settings.products and settings.products.url %}
				<a class="href" href="{{ settings.products.url }}">{{ settings.more_text }} 
          <svg class="arrow-icon" xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
            <g fill="none" class="stroke-current" stroke-width="1.5" stroke-linejoin="round" stroke-miterlimit="10">
              <circle class="arrow-icon--circle" cx="16" cy="16" r="15.12"></circle>
              <path class="arrow-icon--arrow" d="M16.14 9.93L22.21 16l-6.07 6.07M8.23 16h13.98"></path>
            </g>
          </svg>
        </a>
			{% endif %}
	</div>
</section>
{% endif %}